<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Evaluación Enviada</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <main class="container">
